{
  "name": "brewcycle",
  "version": 2,
  "framework": "laravel",
  "buildCommand": "npm run build && php artisan optimize",
  "devCommand": "npm run dev",
  "outputDirectory": "public",
  "installCommand": "composer install --no-dev && npm install",
  "env": {
    "APP_KEY": "@APP_KEY",
    "APP_NAME": "BrewCycle",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "single",
    "APP_URL": "@APP_URL"
  },
  "functions": {
    "api/index.php": {
      "runtime": "php-8.3"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
